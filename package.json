{
  "name": "multi-tenant-task-manager",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"bun run --filter api dev\" \"bun run --filter web dev\"",
    "test": "bun run --filter api test",
    "build": "bun run --filter web build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
